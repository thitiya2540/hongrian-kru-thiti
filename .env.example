NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Legacy projects may use NEXT_PUBLIC_SUPABASE_ANON_KEY instead.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_NAME=ห้องเรียนครูธิติ

# Production checklist
# 1) Add the same values to Vercel Project Settings > Environment Variables.
# 2) Use the Supabase Project URL and publishable key for NEXT_PUBLIC_*.
# 3) This app does not require SUPABASE_SERVICE_ROLE_KEY.
# 4) Set variables for Production, Preview, and Development as appropriate.
